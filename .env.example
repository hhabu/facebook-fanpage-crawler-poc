# Server
PORT=4000
NODE_ENV=development

# Scheduler
SCHEDULER_ENABLED=false
CRAWLER_MAX_CONCURRENCY=2

# Browser engine defaults
# Recommended for first run: true. Set false only when you need a visible browser for profile warm-up.
CLOAK_HEADLESS=true
CLOAK_HUMANIZE=true
CLOAK_LOCALE=vi-VN
CLOAK_TIMEZONE=Asia/Ho_Chi_Minh

# Optional proxy used by CloakBrowser if a bot does not have its own proxyUrl.
# Example: http://user:pass@host:port
CLOAK_PROXY=

# Native Chrome is used for Facebook warm-up/crawling because it behaves closer
# to the facebook_multi_account_manager project than CloakBrowser.
NATIVE_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
NATIVE_CHROME_HEADLESS=false

# Crawler behavior
DEFAULT_RETRY_LIMIT=2
DEFAULT_COOLDOWN_SECONDS=60
